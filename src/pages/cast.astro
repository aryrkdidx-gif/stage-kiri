---
import Layout from '../layouts/Layout.astro';
---

<Layout title="キャスト紹介 | 舞台「霧」">
    <main>
        <h1>CAST</h1>
        <section class="cast-list">
            <div class="cast-item">
                <p>赤澤燈</p>
                <p>松島勇之介</p>
                <p>定本楓馬</p>
                <p>前川優希</p>
                <p>傳谷英里香</p>
                <p>横山涼</p>
                <p>篠原功</p>
                <p>難波なう</p>
                <p>今立進</p>
                <p>宮下貴浩</p>
                <p>安里勇哉</p>
                <p>玉城裕規</p>
            </div>

        </section>
　　　　<nav>
        <a href="/" class="back-link">トップページへ戻る</a>
　　　　</nav>
    </main>
</Layout>

<style>
    /* 1. 全体の土台 */
    main {
        display: flex;
        flex-direction: column; /* 縦に並べる */
        align-items: center;    /* 中央に寄せる */
        gap: 40px;              /* パーツ同士の隙間をあける */
        padding: 60px 20px;     /* 上下に余白を作る（これでスクロールしやすくなる） */
        
        /* 背景の設定 */
          background-image: url('/kiri-bg.jpg'); 
        background-size: cover;               /* 画面いっぱいに広げる */
        background-position: center;          /* 画像の真ん中を使う */
        background-attachment: fixed;         /* スクロールしても背景が動かない（これでお洒落になる） */
        color: white;              /* 文字を白く */
        min-height: 100vh;
        text-align: center;          /* 文字自体も中央揃えにする */
    }

    /* 2. パーツの大きさ調整 */
    img, iframe {
        max-width: 90%;         /* 画面からはみ出さない */
        height: auto;
        border: 1px solid #444; /* 薄い枠線（霧っぽくなる） */
    }

    /* 3. これまでの main の設定はそのまま... */

    .cast-container {
        display: flex;
        flex-direction: column; /* 縦に並べる */
        align-items: center;    /* 中央に寄せる */
        gap: 20px;             /* 名前と名前の間の絶妙な隙間 */
        margin-top: 30px;
    }

    .cast-container p {
        font-size: 1.5rem;      /* 文字を少し大きく */
        letter-spacing: 0.3em; /* 文字の間隔を広げて「舞台っぽさ」を出す */
        font-weight: 300;       /* 文字を細くすると繊細な雰囲気が出る */
    }
    
    h1 {
        font-size: 2.5rem;
        border-bottom: 1px solid white; /* 見出しの下に一本線を入れる */
        padding-bottom: 10px;
        width: 200px;
        text-align: center;
        margin-bottom: 20px;
    }

    a {
        color: white;
        text-decoration: none;
        border: 1px solid white;
        padding: 10px 20px;
        margin-top: 40px;
    }
</style>

