---
import Layout from '../layouts/Layout.astro';
---

<Layout title="キャスト紹介 | 舞台「霧」">
    <main>
        <h1>CAST</h1>
        <section class="cast-list">
            <div class="cast-item">
                <img src="/cast-miyasita.jpg" alt="宮下貴浩" />
                <h2>宮下貴浩</h2>
                <p>本作の演出・出演。劇団「XXX」主宰...</p>
            </div>

            <div class="cast-item">
                <img src="/cast-amu.jpg" alt="私オム" />
                <h2>私オム</h2>
                <p>本作の脚本・出演。独創的な世界観を構築する...</p>
            </div>
        </section>

        <a href="/" class="back-link">トップページへ戻る</a>
    </main>
</Layout>

<style>
    /* 1. 全体の土台 */
    main {
        display: flex;
        flex-direction: column; /* 縦に並べる */
        align-items: center;    /* 中央に寄せる */
        gap: 30px;              /* パーツ同士の隙間をあける */
        padding: 50px 20px;     /* 上下に余白を作る（これでスクロールしやすくなる） */
        
        /* 背景の設定 */
          background-image: url('/kiri-bg.jpg'); 
        background-size: cover;               /* 画面いっぱいに広げる */
        background-position: center;          /* 画像の真ん中を使う */
        background-attachment: fixed;         /* スクロールしても背景が動かない（これでお洒落になる） */
        color: white;              /* 文字を白く */
        min-height: 100vh;
    }

    /* 2. パーツの大きさ調整 */
    img, iframe {
        max-width: 90%;         /* 画面からはみ出さない */
        height: auto;
        border: 1px solid #444; /* 薄い枠線（霧っぽくなる） */
    }
</style>